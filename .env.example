GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Search providers (set one or both; Serper is preferred)
SERPER_API_KEY=
TAVILY_API_KEY=

# Optional Notion logging
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_MCP_URL=

# Optional Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Paths
OUTPUTS_DIR=outputs
RESUMES_DIR=resumes
USER_PROFILE_PATH=context/user_profile.yaml
